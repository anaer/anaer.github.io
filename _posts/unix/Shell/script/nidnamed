#/usr/bin/bash
for filename in `ls -v *.md|grep -v -i README.MD`
do
  echo 恅璃靡 $filename
  if test -f $filename
  then
    #id=$(echo $filename | awk -F '-' '{ print $1 }' )
    newname=$(echo $filename |sed "s/^[0-9]*-//")
    if test $filename != $newname
    then
      echo 笭韜靡 $newname
      mv $filename $newname
    fi
  fi
done
