#/usr/bin/bash
index=1
for filename in `ls -v *.md|grep -v -i README.MD`
do
  #echo index乞多 $index
  echo 匡숭츰 $filename
  if test -f $filename
  then
    #id=$(echo $filename | awk -F '-' '{ print $1 }' )
    newname=$(echo $filename |sed "s/^[0-9]*-//" | sed "s/^/$index-/")
    if test $filename != $newname
    then
      echo 路츱츰 $newname
      mv $filename $newname
    fi
  fi
  index=$(($index+1))
done
