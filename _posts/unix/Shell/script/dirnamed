#/usr/bin/bash
index=1
for dirname in `ls -v` 
do
  #echo index坰竘 $index
  echo 醴翹 $dirname
  if test -d $dirname
  then
    #id=$(echo $dirname | awk -F '-' '{ print $1 }' )
    newname=$(echo $dirname |sed "s/^[0-9]*-//" | sed "s/^/$index-/")
    if test $dirname != $newname
    then
      echo 笭韜靡 $newname
      mv $dirname $newname
    fi
  fi
  index=$(($index+1))
done
